#!/usr/bin/env bash
set -euo pipefail

export DOTFILES_INSTALL_MISE="{{ .install.mise | ternary "1" "0" }}"
export DOTFILES_INSTALL_BREW="{{ .install.brew | ternary "1" "0" }}"
export DOTFILES_INSTALL_OHMYZSH="{{ .install.ohmyzsh | ternary "1" "0" }}"

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
exec /bin/bash "${SCRIPT_DIR}/install/before_finalize.sh" "$@"
