{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "enabledManagers": [
    "github-actions",
    "regex"
  ],
  "regexManagers": [
    {
      "fileMatch": [
        "^versions\\.env$"
      ],
      "matchStrings": [
        "NVM_INSTALL_VERSION=(?<currentValue>v\\d+\\.\\d+\\.\\d+)"
      ],
      "depNameTemplate": "nvm-sh/nvm",
      "datasourceTemplate": "github-tags",
      "versioningTemplate": "semver"
    }
  ]
}
