# Chezmoi configuration (generated from .chezmoi.toml.tmpl in source).
# Run scripts execute in order:
#   1. run_once_after_010_prereqs.sh.tmpl -> install/after_prereqs.sh (after dotfiles; apt, brew, bun, nvm, oh-my-zsh, flyctl)
#   2. run_once_after_090_finalize.sh.tmpl -> install/before_finalize.sh (brew/nvm+Corepack/omz updates; after prereqs)
# chezmoi runs run_once_before_* before any files and run_once_after_* after all files; numeric prefix orders after_* scripts.
# install/after_prereqs.sh applies brew bundle and bun (curl installer) when those prompts are enabled.
# apps.sh is not a runscript; run it manually after apply if needed.
# Test execution is manual via ./scripts/test.sh (no automatic test hook configured here).
# If this template changes, regenerate config with `chezmoi init DiegoFleitas`.

{{ $gitName := "" }}
{{ $gitEmail := "" }}
{{ $instApt := true }}
{{ $instBrew := true }}
{{ $instBun := true }}
{{ $instNvm := true }}
{{ $instOmzsh := true }}
{{ $instFlyctl := false }}

{{/* Codespaces: default DOTFILES_CODESPACES_PROFILE=minimal skips heavy apt/brew/nvm/omz (universal image already includes Node). Set DOTFILES_CODESPACES_PROFILE=full to keep local-like installs. */}}
{{ $csp := env "DOTFILES_CODESPACES_PROFILE" }}
{{ if eq $csp "" }}
{{- if ne (env "CODESPACE_NAME") "" -}}
{{- $csp = "minimal" -}}
{{- else -}}
{{- $csp = "full" -}}
{{- end -}}
{{ end }}
{{ if and (eq $csp "minimal") (ne (env "CODESPACE_NAME") "") }}
{{   $instApt = false }}
{{   $instBrew = false }}
{{   $instBun = false }}
{{   $instNvm = false }}
{{   $instOmzsh = false }}
{{ end }}

{{/* Non-interactive init (e.g. Codespaces dotfiles) may omit .chezmoi.interactive; access would error. */}}
{{ if and (hasKey .chezmoi "interactive") .chezmoi.interactive }}
  {{ $gitName  = promptStringOnce . "git.name"  "Git user.name" }}
  {{ $gitEmail = promptStringOnce . "git.email" "Git user.email" }}
  {{ $instApt    = promptBoolOnce . "install.apt"     "Install apt build dependencies?" }}
  {{ $instBrew   = promptBoolOnce . "install.brew"    "Install Homebrew + Brewfile?" }}
  {{ $instBun    = promptBoolOnce . "install.bun"     "Install Bun?" }}
  {{ $instNvm    = promptBoolOnce . "install.nvm"     "Install nvm and default Node (see ~/.nvmrc)?" }}
  {{ $instOmzsh  = promptBoolOnce . "install.ohmyzsh" "Install oh-my-zsh?" }}
  {{ $instFlyctl = promptBoolOnce . "install.flyctl"  "Install Fly.io CLI?" }}
{{ end }}

[data]
git = { name = {{ $gitName | quote }}, email = {{ $gitEmail | quote }} }
install = { apt = {{ $instApt }}, brew = {{ $instBrew }}, bun = {{ $instBun }}, nvm = {{ $instNvm }}, ohmyzsh = {{ $instOmzsh }}, flyctl = {{ $instFlyctl }} }
codespaces_profile = {{ $csp | quote }}
