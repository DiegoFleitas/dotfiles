# Chezmoi configuration (generated from .chezmoi.toml.tmpl in source).
# Run scripts execute in order:
#   1. run_once_after_prereqs.sh.tmpl -> install/after_prereqs.sh (prompt-gated apt, brew, bun, mise, oh-my-zsh, flyctl)
#   2. run_once_before_finalize.sh.tmpl -> install/before_finalize.sh (shell, brew/omz/pyenv updates as enabled)
# install/after_prereqs.sh applies brew bundle (mise, composer, …) and bun (curl installer) when those prompts are enabled.
# apps.sh is not a runscript; run it manually after apply if needed.
# Test execution is manual via ./scripts/test.sh (no automatic test hook configured here).
# If this template changes, regenerate config with `chezmoi init DiegoFleitas`.

{{ $gitName := "" }}
{{ $gitEmail := "" }}
{{ $instApt := true }}
{{ $instBrew := true }}
{{ $instBun := true }}
{{ $instMise := true }}
{{ $instOmzsh := true }}
{{ $instFlyctl := false }}

{{/* Non-interactive init (e.g. Codespaces dotfiles) may omit .chezmoi.interactive; access would error. */}}
{{ if and (hasKey .chezmoi "interactive") .chezmoi.interactive }}
  {{ $gitName  = promptStringOnce . "git.name"  "Git user.name" }}
  {{ $gitEmail = promptStringOnce . "git.email" "Git user.email" }}
  {{ $instApt    = promptBoolOnce . "install.apt"     "Install apt build dependencies?" }}
  {{ $instBrew   = promptBoolOnce . "install.brew"    "Install Homebrew + Brewfile?" }}
  {{ $instBun    = promptBoolOnce . "install.bun"     "Install Bun?" }}
  {{ $instMise   = promptBoolOnce . "install.mise"    "Install mise toolchains?" }}
  {{ $instOmzsh  = promptBoolOnce . "install.ohmyzsh" "Install oh-my-zsh?" }}
  {{ $instFlyctl = promptBoolOnce . "install.flyctl"  "Install Fly.io CLI?" }}
{{ end }}

[data]
git = { name = {{ $gitName | quote }}, email = {{ $gitEmail | quote }} }
install = { apt = {{ $instApt }}, brew = {{ $instBrew }}, bun = {{ $instBun }}, mise = {{ $instMise }}, ohmyzsh = {{ $instOmzsh }}, flyctl = {{ $instFlyctl }} }
